{
  "manifest_version": 3,
  "name": "Claude Tab Switcher",
  "version": "2.0.0",
  "description": "Lets Claude (via Claude in Chrome) switch tabs, open/close tabs, reload, pin, move, and focus windows.",
  "permissions": ["tabs", "scripting", "windows"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
