{
  "manifest_version": 3,
  "name": "Claude Tab Switcher",
  "version": "1.0.0",
  "description": "Lets Claude (via Claude in Chrome) switch between browser tabs.",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
