{
  "manifest_version": 3,
  "name": "Claude Tab Switcher",
  "version": "3.0.0",
  "description": "Comprehensive browser control for Claude: tabs, windows, bookmarks, downloads, content reading, CSS injection, and more.",
  "permissions": ["tabs", "scripting", "windows", "tabGroups", "bookmarks", "downloads", "contentSettings"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
